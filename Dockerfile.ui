ARG NODE_BASE_IMAGE=node:22-alpine
ARG NGINX_BASE_IMAGE=nginx:1.29-alpine
FROM ${NODE_BASE_IMAGE} AS base

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH

# Optional high-side CA bundle. Pass as build-arg `EXTRA_CA_CERTS_PEM_B64`.
ARG EXTRA_CA_CERTS_PEM_B64=""
RUN if [ -n "$EXTRA_CA_CERTS_PEM_B64" ]; then printf '%s' "$EXTRA_CA_CERTS_PEM_B64" > /etc/CertificateAuthorities.pem; else touch /etc/CertificateAuthorities.pem; fi
ENV NODE_EXTRA_CA_CERTS=/etc/CertificateAuthorities.pem

RUN corepack enable

WORKDIR /workspace

FROM base AS deps

ARG GITLAB_NPM_TOKEN=""

COPY .npmrc pnpm-lock.yaml package.json pnpm-workspace.yaml ./
COPY apps/revolution-api/package.json apps/revolution-api/package.json
COPY apps/revolution-ui/package.json apps/revolution-ui/package.json
COPY packages/shared/package.json packages/shared/package.json
RUN pnpm install --filter revolution-ui... --frozen-lockfile

FROM deps AS build

ARG NODE_OPTIONS=""
ARG VITE_DOCS_URL=/docs

ENV NODE_OPTIONS=$NODE_OPTIONS
ENV VITE_DOCS_URL=$VITE_DOCS_URL

COPY apps/revolution-api apps/revolution-api
COPY apps/revolution-ui apps/revolution-ui
COPY packages/shared packages/shared
RUN pnpm --filter @revolution/shared build && pnpm --filter revolution-ui build

FROM ${NGINX_BASE_IMAGE} AS runtime

COPY docker/nginx/revolution-ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/apps/revolution-ui/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
