{
  "name": "revolution-ui",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run --config vitest.config.ts --coverage",
    "test:unit": "vitest run --config vitest.config.ts src/test/unit",
    "test:integration": "vitest run --config vitest.config.ts src/test/integration",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/ibm-plex-mono": "^5.2.6",
    "@fontsource/space-grotesk": "^5.2.8",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/x-data-grid": "^8.11.2",
    "@revolution/api": "workspace:*",
    "@revolution/shared": "workspace:*",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.7.1",
    "@trpc/react-query": "^11.7.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "superjson": "^2.2.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
