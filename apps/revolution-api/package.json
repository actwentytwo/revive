{
  "name": "@revolution/api",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "exports": {
    "./router": "./src/router.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "lint:fix": "pnpm run lint",
    "test": "vitest run --config vitest.config.ts --coverage",
    "test:unit": "vitest run --config vitest.config.ts src/test/unit",
    "test:integration": "vitest run --config vitest.config.ts src/test/integration",
    "dev:mongo:check": "bash ../../scripts/check-dev-mongo.sh --port-only",
    "dev:mongo:check:full": "bash ../../scripts/check-dev-mongo.sh"
  },
  "dependencies": {
    "mongodb": "^6.18.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@revolution/shared": "workspace:*",
    "@trpc/server": "^11.7.1",
    "@vbrick/rev-client": "^0.25.6",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "swagger-ui-express": "^5.0.1",
    "superjson": "^2.2.2",
    "trpc-to-openapi": "^2.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4"
  }
}
