{
  "name": "revolution",
  "private": true,
  "version": "0.1.1",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@revolution/api",
    "dev:ui": "turbo run dev --filter=revolution-ui",
    "build": "turbo run build",
    "check": "turbo run check && pnpm boundary:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "boundary:check": "node scripts/check-shared-boundary.mjs",
    "version:check": "node scripts/version-check.mjs",
    "prepare": "husky",
    "dev:mongo:up": "bash scripts/start-dev-mongo.sh",
    "dev:mongo:check": "pnpm --filter @revolution/api dev:mongo:check",
    "dev:mongo:check:full": "pnpm --filter @revolution/api dev:mongo:check:full"
  },
  "devDependencies": {
    "dotenv-flow": "^4.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.1",
    "prettier": "^3.6.2",
    "turbo": "^2.5.5"
  }
}
